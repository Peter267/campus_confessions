DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/campus_confessions?sslmode=require"
NEXT_PUBLIC_SITE_NAME="校园万能墙"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_TOKEN="change-me-now"
MODERATION_KEYWORDS="违禁词1,违禁词2,广告,辱骂"
DEFAULT_POST_AUTHOR="匿名同学"

# =========================================================================
# Account system
# =========================================================================
# 会话 cookie 签名密钥，生产环境必须设置（至少 16 字符）
SESSION_SECRET="please-change-me-to-a-long-random-string"
# 验证码 / 重置 token 用的 pepper，与 SESSION_SECRET 隔离（任意字符串）
VERIFICATION_PEPPER="please-change-verification-pepper"
# scrypt 算法的 maxmem（字节），可选，默认 128MiB
# SCRYPT_MAXMEM=134217728

# SMTP 邮件发送（不设置时 dev 模式把验证链接返回到 API 响应）
# SMTP_HOST="smtp.qq.com"
# SMTP_PORT="465"
# SMTP_USER="bot@example.com"
# SMTP_PASSWORD="授权码"
# SMTP_FROM="校园墙 <bot@example.com>"

# 站点配置加密密钥（用于在数据库中加密存储 SMTP 密码 / OAuth clientSecret）。
# 至少 16 字符；生产强烈建议显式设置；缺省时退化为 SESSION_SECRET 的 SHA-256 派生值。
# SITE_SETTINGS_SECRET="please-change-site-settings-secret"

# 第三方 OAuth 登录（环境变量兜底值。推荐在「管理后台 -> 站点配置」中维护）
# OAUTH_GITHUB_CLIENT_ID=
# OAUTH_GITHUB_CLIENT_SECRET=
# OAUTH_GITHUB_REDIRECT_URI="https://your-domain/oauth/github/callback"
# OAUTH_GITHUB_SCOPE="read:user user:email"
# OAUTH_GOOGLE_CLIENT_ID=
# OAUTH_GOOGLE_CLIENT_SECRET=
# OAUTH_GOOGLE_REDIRECT_URI="https://your-domain/oauth/google/callback"
# OAUTH_GOOGLE_SCOPE="openid email profile"
# OAUTH_MICROSOFT_CLIENT_ID=
# OAUTH_MICROSOFT_CLIENT_SECRET=
# OAUTH_MICROSOFT_REDIRECT_URI="https://your-domain/oauth/microsoft/callback"
# OAUTH_MICROSOFT_SCOPE="openid email profile"
# OAUTH_QQ_CLIENT_ID=
# OAUTH_QQ_CLIENT_SECRET=
# OAUTH_QQ_REDIRECT_URI="https://your-domain/oauth/qq/callback"
# OAUTH_QQ_SCOPE="get_user_info"

# Cloudflare Turnstile（人机验证）。不设置时 dev 模式直接放行。
# TURNSTILE_SECRET="0x00000000000000000000-AA"
# NEXT_PUBLIC_TURNSTILE_SITE_KEY="1x00000000000000000000-AA"

# Cloudflare R2（S3 兼容）—— 图片上传
# 在 Cloudflare Dashboard -> R2 -> 创建桶并申请 API Token 后填写
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="campus-confessions"
# 桶的公开访问域名（自定义域或 R2 默认 *.r2.dev 域名）
R2_PUBLIC_BASE="https://pub-xxxxxxxxxxxx.r2.dev"
# 单文件大小上限（字节），超过则拒绝签发预签名 URL
R2_MAX_FILE_SIZE="5242880"
