DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/campus_confessions?sslmode=require"
NEXT_PUBLIC_SITE_NAME="校园万能墙"
NEXT_PUBLIC_SITE_URL="http://localhost:3000"
ADMIN_TOKEN="change-me-now"
MODERATION_KEYWORDS="违禁词1,违禁词2,广告,辱骂"
DEFAULT_POST_AUTHOR="匿名同学"

# Cloudflare R2（S3 兼容）—— 图片上传
# 在 Cloudflare Dashboard -> R2 -> 创建桶并申请 API Token 后填写
R2_ACCOUNT_ID=""
R2_ACCESS_KEY_ID=""
R2_SECRET_ACCESS_KEY=""
R2_BUCKET="campus-confessions"
# 桶的公开访问域名（自定义域或 R2 默认 *.r2.dev 域名）
R2_PUBLIC_BASE="https://pub-xxxxxxxxxxxx.r2.dev"
# 单文件大小上限（字节），超过则拒绝签发预签名 URL
R2_MAX_FILE_SIZE="5242880"
